import { fetchRows } from '../analyze/route.js';

function getPriceEntry(signal) {
  const side = signal.side;

  if (signal.entryPrice) return Number(signal.entryPrice);
  if (signal.entry) return Number(signal.entry);
  if (signal.close) return Number(signal.close);
  if (signal.currentPrice) return Number(signal.currentPrice);

  if (side === 'CALL') return Number(signal.levels?.entryCall);
  if (side === 'PUT') return Number(signal.levels?.entryPut);

  return null;
}

function getStop(signal) {
  if (signal.stop) return Number(signal.stop);

  if (signal.side === 'CALL') return Number(signal.levels?.stopCall);
  if (signal.side === 'PUT') return Number(signal.levels?.stopPut);

  return null;
}

function getTarget(signal) {
  if (signal.target) return Number(signal.target);
  if (signal.target1) return Number(signal.target1);

  if (signal.side === 'CALL') {
    return Number(signal.levels?.targetCall || signal.levels?.target1);
  }

  if (signal.side === 'PUT') {
    return Number(signal.levels?.targetPut || signal.levels?.target1);
  }

  return null;
}

function getDirectionalMove(side, entryPrice, currentPrice) {
  if (!entryPrice || !currentPrice) return 0;

  if (side === 'CALL') {
    return ((currentPrice - entryPrice) / entryPrice) * 100;
  }

  if (side === 'PUT') {
    return ((entryPrice - currentPrice) / entryPrice) * 100;
  }

  return 0;
}

function validateSignal(signal, rows) {
  const side = signal.side;
  const symbol = signal.symbol;
  const mode = signal.mode || 'swing';

  const signalDate = signal.time || signal.date || signal.createdAt || null;

  const entryPrice = getPriceEntry(signal);
  const stop = getStop(signal);
  const target = getTarget(signal);

  const lastRow = rows[rows.length - 1];
  const currentPrice = lastRow?.close || null;
  const lastConsultDate = lastRow?.time || null;

  const directionalMove = Number(
    getDirectionalMove(side, entryPrice, currentPrice).toFixed(2)
  );

  if (!symbol || !side || side === 'NEUTRAL') {
    return {
      ...signal,
      symbol,
      mode,
      signalDate,
      lastConsultDate,
      currentPrice,
      entryPrice,
      stop,
      target,
      directionalMove,
      validationStatus: 'PENDIENTE',
      result: '⏳ PENDIENTE',
      validationReason: 'Señal neutral o sin dirección clara',
      lastValidation: new Date().toLocaleString(),
    };
  }

  if (!entryPrice || !stop || !target) {
    return {
      ...signal,
      symbol,
      mode,
      signalDate,
      lastConsultDate,
      currentPrice,
      entryPrice,
      stop,
      target,
      directionalMove,
      validationStatus: 'PENDIENTE',
      result: '⏳ PENDIENTE',
      validationReason: 'Faltan niveles de entrada, stop o target',
      lastValidation: new Date().toLocaleString(),
    };
  }

  const afterRows = rows.filter((r) => {
    if (!signalDate) return true;
    return new Date(r.time) >= new Date(signalDate);
  });

  for (const row of afterRows) {
    if (side === 'CALL') {
      if (row.low <= stop) {
        return {
          ...signal,
          symbol,
          mode,
          signalDate,
          lastConsultDate,
          currentPrice,
          entryPrice,
          stop,
          target,
          directionalMove,
          validationStatus: 'PERDIDA',
          result: '❌ PERDIDA',
          exitPrice: stop,
          validationTime: row.time,
          validationReason: 'Tocó stop antes del target',
          lastValidation: new Date().toLocaleString(),
        };
      }

      if (row.high >= target) {
        return {
          ...signal,
          symbol,
          mode,
          signalDate,
          lastConsultDate,
          currentPrice,
          entryPrice,
          stop,
          target,
          directionalMove,
          validationStatus: 'GANADA',
          result: '✅ GANADA',
          exitPrice: target,
          validationTime: row.time,
          validationReason: 'Tocó target antes del stop',
          lastValidation: new Date().toLocaleString(),
        };
      }
    }

    if (side === 'PUT') {
      if (row.high >= stop) {
        return {
          ...signal,
          symbol,
          mode,
          signalDate,
          lastConsultDate,
          currentPrice,
          entryPrice,
          stop,
          target,
          directionalMove,
          validationStatus: 'PERDIDA',
          result: '❌ PERDIDA',
          exitPrice: stop,
          validationTime: row.time,
          validationReason: 'Tocó stop antes del target',
          lastValidation: new Date().toLocaleString(),
        };
      }

      if (row.low <= target) {
        return {
          ...signal,
          symbol,
          mode,
          signalDate,
          lastConsultDate,
          currentPrice,
          entryPrice,
          stop,
          target,
          directionalMove,
          validationStatus: 'GANADA',
          result: '✅ GANADA',
          exitPrice: target,
          validationTime: row.time,
          validationReason: 'Tocó target antes del stop',
          lastValidation: new Date().toLocaleString(),
        };
      }
    }
  }

  if (directionalMove >= 0.15) {
    return {
      ...signal,
      symbol,
      mode,
      signalDate,
      lastConsultDate,
      currentPrice,
      entryPrice,
      stop,
      target,
      directionalMove,
      validationStatus: 'ACERTO_DIRECCION',
      result: '🟡 ACERTÓ DIRECCIÓN',
      exitPrice: null,
      validationTime: null,
      validationReason: `Se movió a favor ${directionalMove}% pero aún no toca target`,
      lastValidation: new Date().toLocaleString(),
    };
  }

  return {
    ...signal,
    symbol,
    mode,
    signalDate,
    lastConsultDate,
    currentPrice,
    entryPrice,
    stop,
    target,
    directionalMove,
    validationStatus: 'PENDIENTE',
    result: '⏳ PENDIENTE',
    exitPrice: null,
    validationTime: null,
    validationReason: 'Aún no toca stop ni target',
    lastValidation: new Date().toLocaleString(),
  };
}

export async function POST(req) {
  try {
    const body = await req.json();

    

    const signals = Array.isArray(body.signals)
      ? body.signals
      : body.signal
      ? [body.signal]
      : [];

    if (!signals.length) {
      return Response.json(
        { error: 'No se recibieron señales para validar' },
        { status: 400 }
      );
    }

    const results = [];

    for (const signal of signals) {
      const symbol = signal.symbol;
      const mode = signal.mode || 'swing';

      if (!symbol) {
        results.push({
          ...signal,
          validationStatus: 'PENDIENTE',
          result: '⏳ PENDIENTE',
          validationReason: 'La señal no tiene símbolo',
          lastValidation: new Date().toLocaleString(),
        });
        continue;
      }

      const rows = await fetchRows(symbol, 'intraday');
      const validated = validateSignal(signal, rows);

      results.push(validated);
    }

    const total = results.length;
    const ganadas = results.filter((r) => r.validationStatus === 'GANADA').length;
    const acertoDireccion = results.filter(
      (r) => r.validationStatus === 'ACERTO_DIRECCION'
    ).length;
    const perdidas = results.filter((r) => r.validationStatus === 'PERDIDA').length;
    const pendientes = results.filter((r) => r.validationStatus === 'PENDIENTE').length;

    const cerradasTarget = ganadas + perdidas;
    const conDireccion = ganadas + acertoDireccion + perdidas;

    const efectividadTarget =
      cerradasTarget > 0 ? Math.round((ganadas / cerradasTarget) * 100) : 0;

    const precisionDireccional =
      conDireccion > 0
        ? Math.round(((ganadas + acertoDireccion) / conDireccion) * 100)
        : 0;

    return Response.json({
      results,
      stats: {
        total,
        ganadas,
        acertoDireccion,
        perdidas,
        pendientes,
        cerradasTarget,
        efectividadTarget,
        precisionDireccional,
        lastValidationDate: new Date().toISOString(),
      },
      disclaimer: 'Validación educativa; no es consejo financiero oficial.',
    });
  } catch (e) {
    return Response.json({ error: e.message }, { status: 400 });
  }
}
